# Copie para a raiz do projeto como `.env` (Compose lê automaticamente)
# ou use: docker compose --env-file docker/env.example up

MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=catalogo_ecommerce
MYSQL_USER=laravel
MYSQL_PASSWORD=secret

BACKEND_PORT=8080
FRONTEND_PORT=5173

APP_NAME=Laravel
APP_ENV=local
# Opcional: deixe vazio para gerar no arranque do contentor (não recomendado em produção)
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

# URL da API no browser (serviço backend exposto no host)
VITE_API_URL=http://localhost:8080/api
